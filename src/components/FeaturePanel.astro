---
/*
 * FeaturePanel — right-rail of the landing hero on desktop; stacks below
 * the hero on mobile. Composes 4 cards: latest blog post, latest book,
 * latest package, and the live family counter.
 *
 * Layout owner is `/` (index.astro) — this component is layout-agnostic
 * (renders as a flex column of cards) and only controls card visuals.
 */
import LatestBlogCard from '~/components/feature/LatestBlogCard.astro'
import LatestBookCard from '~/components/feature/LatestBookCard.astro'
import LatestPackageCard from '~/components/feature/LatestPackageCard.astro'
import LiveCounter from '~/components/feature/LiveCounter.astro'
---

<aside class="feature-panel" aria-label="Family highlights">
  <LatestBlogCard />
  <LatestBookCard />
  <LatestPackageCard />
  <LiveCounter />
</aside>

<style is:global>
  .feature-panel {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  /* Shared card chrome — every .fc inside the panel. */
  .feature-panel .fc {
    padding: 1rem 1.125rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }
  .feature-panel .fc-h {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin: 0 0 0.5rem;
  }
  .feature-panel .fc-kicker {
    font-family: var(--font-utility);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }
  .feature-panel .fc-more {
    font-family: var(--font-utility);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-decoration: none;
  }
  .feature-panel .fc-more:hover {
    text-decoration: underline;
  }
  .feature-panel .fc-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.25;
    margin: 0;
    color: var(--color-fg);
  }
  .feature-panel .fc-title a {
    color: inherit;
    text-decoration: none;
  }
  .feature-panel .fc-title a:hover {
    color: var(--color-accent);
  }
  .feature-panel .fc-excerpt {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0.375rem 0 0;
  }
  .feature-panel .fc-meta {
    font-family: var(--font-utility);
    font-size: 0.6875rem;
    color: var(--color-muted);
    display: block;
    margin-top: 0.5rem;
  }
</style>
