---
/*
 * Header — band 1 of the broadsheet. 56px tall, hairline above + below.
 *
 * Layout (matches design-briefs/oriz-home.md band 1):
 *   ─── hairline rule ────────────────────────────────────────────────
 *   ORIZ · ALMANAC          NO. 011 · JUN 2026 · CHIRAG SINGHAL
 *   ─── hairline rule ────────────────────────────────────────────────
 *   sign in                                            (right-aligned)
 *
 * NO nav links — sub-sites are reachable only through the index page.
 * The lone affordance is the underlined `sign in` word at the far right.
 *
 * Family-anchor pattern: every site has its OWN header (per family rules).
 * Sister sites copy this skeleton and substitute their own NO. + section
 * label (e.g. "ORIZ · BLOG", "ORIZ · BOOKS").
 */
import { FAMILY_SITES } from '~/lib/family'

interface Props {
  /** Section name shown after `ORIZ ·`. Defaults to 'ALMANAC' (the home almanac). */
  sectionLabel?: string
  /** Subtitle for the wordmark (used on non-home pages). NOT rendered in this header — the wordmark lives in band 2 on the index. */
  wordmarkSubtitle?: string
}

const { sectionLabel = 'ALMANAC' } = Astro.props

const ISSUE_NO = String(FAMILY_SITES.length).padStart(3, '0')
const month = new Date().toLocaleString('en-US', { month: 'short', year: 'numeric' }).toUpperCase()
---

<header class="header">
  <hr class="hairline" />
  <div class="spine header-row header-meta">
    <span class="meta-left mono">ORIZ · {sectionLabel}</span>
    <span class="meta-right mono">NO. {ISSUE_NO} · {month} · CHIRAG SINGHAL</span>
  </div>
  <hr class="hairline" />
  <div class="spine header-row header-sign">
    <a href="/account/" class="sign-in">sign in</a>
  </div>
</header>

<style>
  .header {
    position: relative;
    /* The header is intentionally NOT sticky — broadsheet pages don't have
       sticky chrome. The page is short enough. */
  }
  .header-row {
    display: flex;
    align-items: center;
    height: 28px; /* 28 + 28 = 56 total */
  }
  .header-meta {
    justify-content: space-between;
    gap: 1rem;
  }
  .header-sign {
    justify-content: flex-end;
  }
  .meta-left,
  .meta-right {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }
  .meta-right {
    text-align: right;
  }
  .sign-in {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--ink-mute);
  }
  .sign-in:hover {
    color: var(--mustard);
    text-decoration-color: var(--mustard);
  }
  .sign-in:focus-visible {
    outline: 2px solid var(--mustard);
    outline-offset: 2px;
    text-decoration-color: var(--mustard);
  }

  /* Drop the hairline collapse on small screens — keep the strip 56px. */
  @media (max-width: 480px) {
    .meta-right {
      font-size: 10px;
      letter-spacing: 0.08em;
    }
  }
</style>
