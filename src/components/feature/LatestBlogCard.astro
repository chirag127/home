---
/*
 * LatestBlogCard — top-1 from blog.oriz.in. Uses a build-time fetch with a
 * hardcoded fallback so the home page never breaks if the feed is down.
 *
 * v0 lazy: hardcoded fallback (per the brief). When blog content stabilises,
 * promote to `data/latest.json` committed per app.
 */
type LatestPost = {
  title: string
  url: string
  excerpt: string
  date: string
}

const FALLBACK: LatestPost = {
  title: 'Building 25 apps with one design system',
  url: 'https://blog.oriz.in/',
  excerpt:
    'How one design token sheet, one shell package, and one knowledge base let one person ship 25 small apps without losing the plot.',
  date: '2026-06-22',
}

let post: LatestPost = FALLBACK
try {
  const res = await fetch('https://blog.oriz.in/feed.json', {
    signal: AbortSignal.timeout(2500),
  })
  if (res.ok) {
    const feed = (await res.json()) as {
      items?: Array<{
        title?: string
        url?: string
        summary?: string
        content_text?: string
        date_published?: string
      }>
    }
    const first = feed.items?.[0]
    if (first?.title && first.url) {
      post = {
        title: first.title,
        url: first.url,
        excerpt:
          (first.summary || first.content_text || '').slice(0, 160) ||
          'Read the latest essay on engineering, finance, and books.',
        date: first.date_published?.slice(0, 10) || FALLBACK.date,
      }
    }
  }
} catch {
  // Network blocked at build time — fallback wins.
}
---

<article class="fc fc-blog">
  <header class="fc-h">
    <span class="fc-kicker">Latest essay</span>
    <a class="fc-more" href="https://blog.oriz.in/">Blog →</a>
  </header>
  <h3 class="fc-title">
    <a href={post.url}>{post.title}</a>
  </h3>
  <p class="fc-excerpt">{post.excerpt}</p>
  <time class="fc-meta" datetime={post.date}>{post.date}</time>
</article>

<style>
  .fc-blog {
    background: #fff;
    border-left: 3px solid var(--color-accent);
  }
</style>
