---
/*
 * LatestPackageCard — top-1 from @chirag127/* npm packages.
 *
 * v0 lazy: hardcoded latest package + version. Promote to a build-time
 * fetch from the npm registry (`https://registry.npmjs.org/-/v1/search?text=maintainer:chirag127`)
 * or the packages-catalog data file once it stabilises.
 */
const LATEST_PKG = {
  name: '@chirag127/astro-shell',
  short: 'astro-shell',
  version: '0.1.3',
  blurb: 'The shared Astro shell — design tokens, layout primitives, and chrome.',
  url: 'https://npm.im/@chirag127/astro-shell',
}
---

<article class="fc fc-pkg">
  <header class="fc-h">
    <span class="fc-kicker">Latest package</span>
    <a class="fc-more" href="https://packages.oriz.in">Packages →</a>
  </header>
  <h3 class="fc-title">
    <a href={LATEST_PKG.url}>{LATEST_PKG.short}</a>
    <span class="fc-pkg-v">v{LATEST_PKG.version}</span>
  </h3>
  <p class="fc-excerpt">{LATEST_PKG.blurb}</p>
  <pre class="fc-pkg-cmd"><code>npm i {LATEST_PKG.name}</code></pre>
</article>

<style>
  .fc-pkg {
    background: #fff;
    border-left: 3px solid var(--color-fg);
  }
  .fc-pkg-v {
    font-family: var(--font-utility);
    font-size: 0.6875rem;
    color: var(--color-muted);
    margin-left: 0.375rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .fc-pkg-cmd {
    font-family: var(--font-utility);
    font-size: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.625rem;
    margin: 0.5rem 0 0;
    overflow-x: auto;
    color: var(--color-fg);
    line-height: 1.4;
  }
  .fc-pkg-cmd code {
    font-family: inherit;
  }
</style>
