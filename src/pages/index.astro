---
/*
 * oriz / home — index page (Alphabet-style parent-company landing).
 *
 * Modeled after https://abc.xyz — pure white background, single ~720px
 * centered column, serif everywhere, no header/footer chrome, plain rows
 * of subsidiary sites. Replaces the prior broadsheet-almanac aesthetic
 * because the brief is "look like the parent company landing page".
 *
 * Bands on the page (top → bottom):
 *   1. Wordmark (`oriz`) — large serif, top-left.
 *   2. One-paragraph hero (~50 words) — explains what oriz is.
 *   3. Sites — 10-row plain list (name · description · subdomain).
 *   4. Latest from the blog — 5 most recent posts pulled from
 *      https://blog.oriz.in/rss.xml at build time. Graceful fallback if
 *      the feed is missing (the blog may not be deployed yet).
 *   5. More — GitHub, Support, Privacy, Search the web (MultiSearch).
 *   6. StatusBanner — invisible unless an incident is live.
 *   7. Tiny colophon line (© 2026 · operator) — keeps "small + plain" rule.
 *
 * BaseLayout is invoked with chrome="bare" (no Header / no Footer) and a
 * body class of "home-bare" which flips the global tokens to
 * white-paper / near-black-ink / serif-everywhere (see global.css).
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import MultiSearch from '~/components/MultiSearch.tsx'
import StatusBanner from '~/components/StatusBanner.tsx'

import Parser from 'rss-parser'

/*
 * The 10 sister-site rows. Order matches the brief.
 * Plain { name, desc, domain, url } — no categories, no numbering.
 * The current `home` slug is excluded (this IS the home page).
 */
const SITES: { name: string; desc: string; domain: string; url: string }[] = [
  { name: 'Blog',        desc: 'Long-form essays + tutorials.',     domain: 'blog.oriz.in',        url: 'https://blog.oriz.in' },
  { name: 'Books',       desc: 'Reading log + book reviews.',       domain: 'books.oriz.in',       url: 'https://books.oriz.in' },
  { name: 'Book Lore',   desc: 'Knowledge graph from books.',       domain: 'book-lore.oriz.in',   url: 'https://book-lore.oriz.in' },
  { name: 'Cards',       desc: 'Spaced-repetition flashcards.',     domain: 'cards.oriz.in',       url: 'https://cards.oriz.in' },
  { name: 'Finance',     desc: 'Personal finance dashboard.',       domain: 'finance.oriz.in',     url: 'https://finance.oriz.in' },
  { name: 'Image Tools', desc: 'Browser image utilities.',          domain: 'image-tools.oriz.in', url: 'https://image-tools.oriz.in' },
  { name: 'Journal',     desc: 'Daily journal.',                    domain: 'journal.oriz.in',     url: 'https://journal.oriz.in' },
  { name: 'Me',          desc: 'Lifestream.',                       domain: 'me.oriz.in',          url: 'https://me.oriz.in' },
  { name: 'PDF Tools',   desc: 'Browser PDF utilities.',            domain: 'pdf-tools.oriz.in',   url: 'https://pdf-tools.oriz.in' },
  { name: 'URLs to MD',  desc: 'URL → clean Markdown.',             domain: 'urls-to-md.oriz.in',  url: 'https://urls-to-md.oriz.in' },
]

/*
 * Latest 5 posts from the blog feed. Build-time fetch via rss-parser.
 * The blog site may not be deployed yet — wrap in try/catch and degrade
 * gracefully ("Blog launching soon — see github…"). Never let an RSS
 * failure break the build.
 */
interface Post {
  title: string
  link: string
  pubDate: string
}

let posts: Post[] = []
let blogFetchOk = false
try {
  const parser = new Parser({ timeout: 8000 })
  const feed = await parser.parseURL('https://blog.oriz.in/rss.xml')
  posts = (feed.items ?? []).slice(0, 5).map((i) => ({
    title: i.title ?? '(untitled)',
    link: i.link ?? 'https://blog.oriz.in',
    pubDate: i.pubDate ?? i.isoDate ?? '',
  }))
  blogFetchOk = posts.length > 0
} catch {
  posts = []
  blogFetchOk = false
}

function fmtDate(iso: string): string {
  if (!iso) return ''
  const d = new Date(iso)
  if (Number.isNaN(d.getTime())) return ''
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })
}
---

<BaseLayout
  chrome="bare"
  bodyClass="home-bare"
  title="oriz — a family of free-forever, recruiter-grade web tools"
  description="oriz is a family of free-forever, recruiter-grade web tools and reading sites built and maintained by Chirag Singhal. One sign-in, one design system, one knowledge base."
>
  {/* Status banner — renders nothing unless an active incident is live. */}
  <div class="status-mount"><StatusBanner client:load siteId="home" /></div>

  <article class="page">
    {/* 1 — Wordmark. Plain text serif, no decoration. */}
    <h1 class="brand">oriz</h1>

    {/* 2 — Hero paragraph, ~50 words. */}
    <p class="lede">
      oriz is a family of free-forever, recruiter-grade web tools and reading
      sites built and maintained by Chirag Singhal. Every site shares a single
      sign-in, a single design system, and a single knowledge base — small,
      static, and built to outlive their author.
    </p>

    {/* 3 — Sites list. Plain rows, no card chrome. */}
    <h2 class="section-h">Sites</h2>
    <ul class="sites">
      {
        SITES.map((s) => (
          <li class="site-row">
            <a class="site-link" href={s.url}>
              <strong class="site-name">{s.name}</strong>
              <span class="site-desc">{s.desc}</span>
              <span class="site-domain">{s.domain}</span>
            </a>
          </li>
        ))
      }
    </ul>

    {/* 4 — Latest from the blog. Build-time RSS, graceful fallback. */}
    <h2 class="section-h">Latest from the blog</h2>
    {
      blogFetchOk ? (
        <ul class="posts">
          {posts.map((p) => (
            <li class="post-row">
              <span class="post-date">{fmtDate(p.pubDate)}</span>
              <span class="post-sep" aria-hidden="true">·</span>
              <a class="post-link" href={p.link}>
                {p.title}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="post-fallback">
          Blog launching soon — see{' '}
          <a href="https://github.com/chirag127/oriz-blog-site">github.com/chirag127/oriz-blog-site</a>.
        </p>
      )
    }

    {/* 5 — More. Plain links, including the MultiSearch popover. */}
    <h2 class="section-h">More</h2>
    <ul class="more">
      <li>
        <span class="more-name">GitHub</span>
        <a href="https://github.com/chirag127/oriz">github.com/chirag127/oriz</a>
      </li>
      <li>
        <span class="more-name">Support</span>
        <a href="/support/">/support</a>
      </li>
      <li>
        <span class="more-name">Privacy</span>
        <a href="/privacy/">/privacy</a>
      </li>
      <li>
        <span class="more-name">Search the web</span>
        <span class="search-mount">
          <MultiSearch client:idle titleSuffix=" — oriz" label="Search the web →" />
        </span>
      </li>
    </ul>

    {/* 7 — Tiny colophon. */}
    <p class="colophon">© 2026 Chirag Singhal · Bhubaneswar, IN</p>
  </article>
</BaseLayout>

<style>
  /* ── Page scaffold ──────────────────────────────────────────────────── */

  .status-mount {
    /* Status banner is dismissible / hidden by default — keep it pinned to
       the top so it doesn't displace the page above the fold normally. */
    width: 100%;
  }

  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1.25rem, 4vw, 2rem)
      clamp(3rem, 8vw, 5rem);
  }

  /* ── 1 · Wordmark ──────────────────────────────────────────────────── */

  .brand {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 3.25rem);
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0 0 clamp(1.5rem, 4vw, 2.25rem);
    color: var(--ink);
  }

  /* ── 2 · Hero paragraph ────────────────────────────────────────────── */

  .lede {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 0 0 clamp(2.25rem, 6vw, 3.25rem);
    color: var(--ink);
    max-width: 60ch;
  }

  /* ── Section headings — small caps, regular weight ─────────────────── */

  .section-h {
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: 'smcp' 1, 'c2sc' 1;
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    margin: clamp(2rem, 5vw, 2.75rem) 0 clamp(0.75rem, 2vw, 1rem);
  }

  /* ── 3 · Sites list ────────────────────────────────────────────────── */

  .sites,
  .posts,
  .more {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-row {
    border-top: 1px solid var(--rule);
  }
  .site-row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .site-link {
    display: grid;
    grid-template-columns: 7.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.625rem;
    color: inherit;
    text-decoration: none;
  }
  .site-link:hover {
    text-decoration: none;
  }
  .site-link:hover .site-name,
  .site-link:hover .site-domain {
    color: var(--accent);
  }
  .site-link:hover .site-domain {
    text-decoration: underline;
  }

  .site-name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
  }
  .site-desc {
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--ink);
  }
  .site-domain {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--ink-mute);
    text-align: right;
    white-space: nowrap;
  }

  /* ── 4 · Latest blog posts ─────────────────────────────────────────── */

  .post-row {
    padding-block: 0.375rem;
    color: var(--ink);
  }
  .post-date {
    font-family: var(--font-display);
    color: var(--ink-mute);
    font-size: 0.9375rem;
    display: inline-block;
    min-width: 6.5rem;
  }
  .post-sep {
    color: var(--ink-mute);
    margin-inline: 0.5rem;
  }
  .post-link {
    color: var(--accent);
  }
  .post-fallback {
    margin: 0;
    color: var(--ink-mute);
  }

  /* ── 5 · More section ──────────────────────────────────────────────── */

  .more li {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1rem;
    padding-block: 0.375rem;
    align-items: baseline;
  }
  .more-name {
    color: var(--ink);
  }
  .search-mount {
    display: inline-block;
  }

  /* MultiSearch trigger — render as a plain inline link, not a button. */
  .search-mount :global([data-oriz-multisearch='trigger']) {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--accent);
    font: inherit;
    font-family: var(--font-display);
    font-size: 1rem;
    cursor: pointer;
  }
  .search-mount :global([data-oriz-multisearch='trigger']:hover) {
    text-decoration: underline;
  }
  .search-mount :global([data-oriz-multisearch='trigger']:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .search-mount :global([data-oriz-multisearch='popover']) {
    position: absolute;
    margin-top: 0.25rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0.75rem;
    z-index: 50;
    min-width: 240px;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }
  .search-mount :global([data-oriz-multisearch='query']) {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
    max-width: 220px;
  }
  .search-mount :global([data-oriz-multisearch='list']) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .search-mount :global([data-oriz-multisearch='engine']) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.375rem 0.5rem;
    color: var(--ink);
    text-decoration: none;
  }
  .search-mount :global([data-oriz-multisearch='engine']:hover) {
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    color: var(--accent);
    text-decoration: none;
  }
  .search-mount :global([data-oriz-multisearch='glyph']) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 0.6875rem;
    color: var(--ink-mute);
    border: 1px solid var(--rule);
  }

  /* ── 6 · Status banner styling on white paper ──────────────────────── */

  .status-mount :global([data-oriz-status]) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--ink);
    background: #fff8db; /* mild yellow strap, not the dark broadsheet mustard */
    border-bottom: 1px solid var(--rule);
    text-align: center;
  }
  .status-mount :global([data-oriz-status='partial_outage']) {
    background: #fdecd5;
  }
  .status-mount :global([data-oriz-status='major_outage']) {
    background: #fde2dc;
  }
  .status-mount :global([data-oriz-status='maintenance']) {
    background: #e6f3ec;
  }
  .status-mount :global([data-oriz-status-link]) {
    color: var(--accent);
    text-decoration: underline;
  }
  .status-mount :global([data-oriz-status-dismiss]) {
    margin-left: auto;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    padding: 0 0.25rem;
  }

  /* ── 7 · Colophon ──────────────────────────────────────────────────── */

  .colophon {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
    color: var(--ink-mute);
    font-size: 0.875rem;
  }

  /* ── Mobile — collapse rows to two-line stacks. ────────────────────── */
  @media (max-width: 560px) {
    .site-link {
      grid-template-columns: 1fr;
      grid-template-areas:
        'name'
        'desc'
        'domain';
      gap: 0.125rem;
    }
    .site-name { grid-area: name; }
    .site-desc { grid-area: desc; color: var(--ink-mute); font-size: 0.9375rem; }
    .site-domain { grid-area: domain; text-align: left; }

    .more li {
      grid-template-columns: 1fr;
      gap: 0.125rem;
    }
    .post-date {
      min-width: 0;
      display: block;
    }
    .post-sep {
      display: none;
    }
    .post-link {
      display: block;
    }
  }
</style>
