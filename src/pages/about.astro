---
import BaseLayout from '~/layouts/BaseLayout.astro'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chirag Singhal',
  url: 'https://oriz.in/about/',
  jobTitle: 'Software Engineer',
  description: 'Software engineer specializing in scalable backend architectures, full-stack development, AI agents, and cloud-native deployments.',
  address: { '@type': 'PostalAddress', addressLocality: 'Bhubaneswar', addressRegion: 'Odisha', addressCountry: 'IN' },
  sameAs: ['https://github.com/chirag127', 'https://x.com/chirag127', 'https://linkedin.com/in/chirag127'],
}
---

<BaseLayout
  title="About — Chirag Singhal"
  description="Software engineer based in Bhubaneswar. Builder of the oriz family of sites."
  jsonLd={jsonLd}
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">oriz</a> / About</p>
    <h1>About</h1>
  </header>

  <article class="container-prose prose">
    <p class="lede">
      I am Chirag Singhal — a software engineer based in Bhubaneswar, Odisha.
      I build small, fast, free things on the open web.
    </p>

    <h2>What is oriz</h2>
    <p>
      <strong>oriz</strong> is the umbrella for everything I publish — a family
      of static sites that share a sign-in, a design system, and a single
      principle: <em>useful, free, and quiet</em>. No newsletters you didn't
      ask for. No popups. No paid tier. No tracking beyond Cloudflare's
      first-party analytics.
    </p>
    <p>
      Each site is its own GitHub repository. They are stitched together
      through <a href="https://github.com/chirag127/oriz">chirag127/oriz</a>,
      a hub that holds them as git submodules. Hosting is split between
      Cloudflare (for static reading sites) and Firebase (for app-like sites
      with auth and a database). Display ads on a few of them cover the domain
      renewal.
    </p>

    <h2>What I do</h2>
    <p>
      Day job: backend systems, distributed databases, and cloud platforms.
      Off-hours: writing, building these tools, reading.
    </p>
    <p>
      If something on oriz is useful to you, that is enough. If you find a
      bug, the issue tracker is at
      <a href="https://github.com/chirag127">github.com/chirag127</a>.
    </p>

    <h2>Contact</h2>
    <p>
      Email: <a href="mailto:whyiswhen@gmail.com">whyiswhen@gmail.com</a>.
      Or use the <a href="/contact/">contact form</a> for anything site-related.
    </p>
  </article>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--color-fg); }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.75; font-size: 1.0625rem; }
  .prose .lede { font-size: 1.1875rem; color: var(--color-fg); margin: 0 0 2rem; }
  .prose h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; color: var(--color-fg); margin: 2.5rem 0 1rem; }
  .prose p { margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
</style>
