---
import AccountPanel from '~/components/AccountPanel.tsx'
/*
 * /account — sign-in / sign-out via Firebase Auth.
 * The AccountPanel island uses `data-oriz-account-*` selector hooks; styling
 * lives in src/styles/oriz-ui-overrides.css.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Account — oriz"
  description="Sign in to oriz. One account works across every oriz site."
  noindex={true}
  wordmarkSubtitle="account"
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">oriz</a> / account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site. Bookmarks, reading history, and journal entries
      follow you.
    </p>
  </header>

  <section class="spine prose">
    <AccountPanel client:load />
  </section>
</BaseLayout>
