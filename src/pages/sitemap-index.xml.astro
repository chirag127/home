---
/*
 * /sitemap-index.xml — XML sitemap index pointing to all family-app sitemaps.
 * Uses SitemapIndex from @chirag127/astro-chrome with format="xml".
 */
import SitemapIndex from '@chirag127/astro-chrome/legal/SitemapIndex.astro'
import { FAMILY_SITES } from '~/lib/family'
const apps = FAMILY_SITES.map((s) => ({ name: s.name, url: s.url }))
---
<SitemapIndex appName="Oriz" appDomain="oriz.in" apps={apps} format="xml" lastUpdated="2026-06-22" />
