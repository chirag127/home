---
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Sign out — oriz"
  description="Sign out of Oriz."
  noindex={true}
>
  <header class="spine page-head">
    <p class="eyebrow"><a href="/">oriz</a> / sign out</p>
    <h1>Sign out</h1>
    <p class="lede">Sign-out is handled inside the account panel.</p>
  </header>

  <section class="spine prose">
    <p>
      Head to <a href="/account/">/account</a> and click <em>Sign out</em>.
      Your reading history and bookmarks stay synced once you sign back in
      on any Oriz site.
    </p>
  </section>
</BaseLayout>
